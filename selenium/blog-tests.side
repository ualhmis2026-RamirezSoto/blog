    {
      "id": "t-contacto-fields",
      "name": "CONTACTO-01 Formulario con 4 campos visibles",
      "commands": [
        {
          "id": "c1",
          "comment": "",
          "command": "open",
          "target": "/contacto.html",
          "targets": [],
          "value": ""
        },
        {
          "id": "c2",
          "comment": "",
          "command": "assertTitle",
          "target": "Contacto",
          "targets": [],
          "value": ""
        },
        {
          "id": "c3",
          "comment": "Campo nombre",
          "command": "assertElementPresent",
          "target": "css=input[name='nombre']",
          "targets": [],
          "value": ""
        },
        {
          "id": "c4",
          "comment": "Campo correo tipo email",
          "command": "assertElementPresent",
          "target": "css=input[name='correo'][type='email']",
          "targets": [],
          "value": ""
        },
        {
          "id": "c5",
          "comment": "Campo asunto",
          "command": "assertElementPresent",
          "target": "css=input[name='asunto']",
          "targets": [],
          "value": ""
