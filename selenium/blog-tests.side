        {
          "id": "c6",
          "comment": "Campo mensaje",
          "command": "assertElementPresent",
          "target": "css=textarea[name='mensaje']",
          "targets": [],
          "value": ""
        },
        {
          "id": "c7",
          "comment": "Boton enviar",
          "command": "assertElementPresent",
          "target": "xpath=//button[@type='submit' and contains(., 'Enviar')]",
          "targets": [],
          "value": ""
        },
        {
          "id": "c8",
          "comment": "El formulario apunta a Formspree",
          "command": "assertElementPresent",
          "target": "css=form[action*='formspree.io']",
          "targets": [],
          "value": ""
        }
      ]
    },
    {
      "id": "t-contacto-ko-vacio",
      "name": "CONTACTO-KO-01 Envio con campos vacios (HTML5)",
      "commands": [
        {
          "id": "c1",
          "comment": "",
          "command": "open",
          "target": "/contacto.html",
          "targets": [],
          "value": ""
        },
        {
          "id": "c2",
          "comment": "Pulsar enviar con todo vacio",
          "command": "click",
          "target": "xpath=//button[@type='submit']",
          "targets": [],
          "value": ""
        },
        {
          "id": "c3",
          "comment": "Leer validationMessage del campo nombre (que es required)",
          "command": "executeScript",
          "target": "return document.querySelector(\"input[name='nombre']\").validationMessage",
          "targets": [],
          "value": "message"
        },
        {
          "id": "c4",
          "comment": "",
          "command": "echo",
          "target": "${message}",
          "targets": [],
          "value": ""
        },
        {
          "id": "c5",
          "comment": "Debe haber mensaje no vacio (texto depende de navegador/idioma)",
          "command": "verifyNotEquals",
          "target": "${message}",
          "targets": [],
          "value": ""
        }
      ]
    },
    {
      "id": "t-contacto-ko-email",
      "name": "CONTACTO-KO-02 Email mal formado (HTML5)",
      "commands": [
        {
          "id": "c1",
          "comment": "",
          "command": "open",
          "target": "/contacto.html",
          "targets": [],
          "value": ""
        },
        {
          "id": "c2",
          "comment": "",
          "command": "executeScript",
          "target": "var e=document.querySelector('input[name=\\'nombre\\']'); e.focus(); e.value='Bruno Tester'; e.dispatchEvent(new Event('input',{bubbles:true})); e.dispatchEvent(new Event('change',{bubbles:true}));",
          "targets": [],
          "value": ""
        },
        {
          "id": "c3",
          "comment": "Email invalido",
          "command": "executeScript",
          "target": "var e=document.querySelector('input[name=\\'correo\\']'); e.focus(); e.value='esto-no-es-email'; e.dispatchEvent(new Event('input',{bubbles:true})); e.dispatchEvent(new Event('change',{bubbles:true}));",
          "targets": [],
          "value": ""
        },
        {
          "id": "c4",
          "comment": "",
          "command": "executeScript",
          "target": "var e=document.querySelector('input[name=\\'asunto\\']'); e.focus(); e.value='Asunto de prueba'; e.dispatchEvent(new Event('input',{bubbles:true})); e.dispatchEvent(new Event('change',{bubbles:true}));",
          "targets": [],
          "value": ""
        },
        {
          "id": "c5",
          "comment": "",
          "command": "executeScript",
          "target": "var e=document.querySelector('textarea[name=\\'mensaje\\']'); e.focus(); e.value='Mensaje de prueba'; e.dispatchEvent(new Event('input',{bubbles:true})); e.dispatchEvent(new Event('change',{bubbles:true}));",
          "targets": [],
          "value": ""
        },
        {
          "id": "c6",
          "comment": "",
          "command": "click",
          "target": "xpath=//button[@type='submit']",
          "targets": [],
          "value": ""
        },
        {
          "id": "c7",
          "comment": "",
          "command": "executeScript",
          "target": "return document.querySelector(\"input[name='correo']\").validationMessage",
          "targets": [],
          "value": "message"
        },
        {
          "id": "c8",
          "comment": "",
          "command": "echo",
          "target": "${message}",
          "targets": [],
          "value": ""
        },
        {
          "id": "c9",
          "comment": "",
          "command": "verifyNotEquals",
          "target": "${message}",
          "targets": [],
          "value": ""
        }
      ]
    },
    {
      "id": "t-contacto-ok-rellenar",
      "name": "CONTACTO-OK Rellenar todos los campos (sin enviar al servidor)",
      "commands": [
        {
          "id": "c1",
          "comment": "",
          "command": "open",
          "target": "/contacto.html",
          "targets": [],
          "value": ""
        },
        {
          "id": "c2",
          "comment": "",
          "command": "executeScript",
          "target": "var e=document.querySelector('input[name=\\'nombre\\']'); e.focus(); e.value='Bruno Selenium'; e.dispatchEvent(new Event('input',{bubbles:true})); e.dispatchEvent(new Event('change',{bubbles:true}));",
          "targets": [],
          "value": ""
        },
        {
          "id": "c3",
          "comment": "",
          "command": "executeScript",
          "target": "var e=document.querySelector('input[name=\\'correo\\']'); e.focus(); e.value='bruno@ual.es'; e.dispatchEvent(new Event('input',{bubbles:true})); e.dispatchEvent(new Event('change',{bubbles:true}));",
          "targets": [],
          "value": ""
        },
        {
          "id": "c4",
          "comment": "",
          "command": "executeScript",
          "target": "var e=document.querySelector('input[name=\\'asunto\\']'); e.focus(); e.value='Asunto valido'; e.dispatchEvent(new Event('input',{bubbles:true})); e.dispatchEvent(new Event('change',{bubbles:true}));",
          "targets": [],
          "value": ""
        },
        {
          "id": "c5",
          "comment": "",
          "command": "executeScript",
          "target": "var e=document.querySelector('textarea[name=\\'mensaje\\']'); e.focus(); e.value='Mensaje valido escrito por Selenium para test de aceptacion'; e.dispatchEvent(new Event('input',{bubbles:true})); e.dispatchEvent(new Event('change',{bubbles:true}));",
          "targets": [],
          "value": ""
        },
        {
          "id": "c6",
          "comment": "Verificar checkValidity sin enviar (evita pegar Formspree)",
          "command": "executeScript",
          "target": "return document.querySelector('form').checkValidity()",
          "targets": [],
          "value": "valid"
        },
        {
          "id": "c7",
          "comment": "",
          "command": "verifyEquals",
          "target": "${valid}",
          "targets": [],
          "value": "true"
        }
      ]
    },
