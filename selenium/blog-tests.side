          "target": "xpath=//div[contains(@class,'card')]//h3//a",
          "targets": [],
          "value": ""
        },
        {
          "id": "c4",
          "comment": "Al menos una entrada tiene fecha 'Publicado el'",
          "command": "assertElementPresent",
          "target": "xpath=//p[contains(., 'Publicado el')]",
          "targets": [],
          "value": ""
        }
      ]
    },
