{
  "id": "blog-suite-2026-sesion04",
  "version": "2.0",
  "name": "Blog Equipo - Tests Sesion 04",
  "url": "https://ualhmis2026-ramirezsoto.github.io/blog",
  "tests": [
    {
      "id": "t-index-title",
      "name": "INDEX-01 Titulo del blog visible",
      "commands": [
        {
          "id": "c1",
          "comment": "",
          "command": "open",
          "target": "/",
          "targets": [],
          "value": ""
        },
        {
          "id": "c2",
          "comment": "",
          "command": "setWindowSize",
          "target": "1280x800",
          "targets": [],
          "value": ""
        },
        {
          "id": "c3",
          "comment": "El titulo del documento contiene 'Blog'",
          "command": "assertTitle",
          "target": "Blog del Equipo RamirezSoto",
          "targets": [],
          "value": ""
        },
        {
          "id": "c4",
          "comment": "Encabezado principal h1 con titulo",
          "command": "assertElementPresent",
          "target": "css=h1",
          "targets": [],
          "value": ""
        },
        {
          "id": "c5",
          "comment": "",
          "command": "assertText",
          "target": "css=h1",
          "targets": [],
          "value": "Blog del Equipo RamirezSoto"
        }
      ]
    },
    {
      "id": "t-index-about",
      "name": "INDEX-02 Descripcion del equipo (Sobre nosotros)",
      "commands": [
        {
          "id": "c1",
          "comment": "",
          "command": "open",
          "target": "/",
          "targets": [],
          "value": ""
        },
        {
          "id": "c2",
          "comment": "Seccion Sobre nosotros visible",
          "command": "assertElementPresent",
          "target": "xpath=//h2[contains(., 'Sobre nosotros')]",
          "targets": [],
          "value": ""
        },
        {
          "id": "c3",
          "comment": "Hay un parrafo de descripcion bajo la seccion",
          "command": "assertElementPresent",
          "target": "xpath=//h2[contains(., 'Sobre nosotros')]/following-sibling::p",
          "targets": [],
          "value": ""
        }
      ]
    },
    {
      "id": "t-index-posts-list",
