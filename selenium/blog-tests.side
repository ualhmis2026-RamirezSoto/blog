  "suites": [
    {
      "id": "suite-blog",
      "name": "Blog - Suite completa Sesion 04",
      "persistSession": false,
      "parallel": false,
      "timeout": 300,
      "tests": [
        "t-index-title",
        "t-index-about",
        "t-index-posts-list",
        "t-index-links-equipo",
        "t-index-link-contacto",
        "t-post-view",
        "t-bruno-page",
        "t-soto-page",
        "t-contacto-fields",
        "t-contacto-ko-vacio",
        "t-contacto-ko-email",
        "t-contacto-ok-rellenar",
        "t-volver-inicio"
      ]
    }
